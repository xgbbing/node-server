{
  "name": "node-server",
  "version": "1.0.0",
  "private": true,
  "description": "A Midway + Koa + SQLite + TypeScript project with authentication, scheduled tasks, queue, ES, remote calls, API, templates, and more",
  "scripts": {
    "mock-dev": "mwtsc --watch --run @midwayjs/mock/app.js",
    "prod-dev": "npm run build && npm run compress && NODE_ENV=production node ./dist/bootstrap.js",
    "start": "NODE_ENV=production node ./dist/bootstrap.js",
    "build": "mwtsc --cleanOutDir",
    "compress": "node ./src/scripts/compress.js",
    "dev": "cross-env NODE_ENV=local midway-bin dev --ts",
    "cli-build": "midway-bin build -c",
    "test": "cross-env NODE_ENV=test midway-bin test --ts",
    "cov": "cross-env NODE_ENV=test midway-bin cov --ts",
    "lint": "eslint --ext .ts,.js .",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "typeorm:gen": "npm run typeorm migration:generate -- -d ormconfig.ts",
    "typeorm:run": "npm run typeorm migration:run -- -d ormconfig.ts",
    "bundle": "bundle && npm run build && ncc build bootstrap.js -o build",
    "bundle_start": "NODE_ENV=production node ./build/index.js"
  },
  "dependencies": {
    "@midwayjs/axios": "^3.20.24",
    "@midwayjs/bootstrap": "^3.20.24",
    "@midwayjs/core": "^3.20.24",
    "@midwayjs/koa": "^3.20.24",
    "@midwayjs/logger": "^3.4.2",
    "@midwayjs/typeorm": "^3.20.24",
    "@midwayjs/view-nunjucks": "^3.0.0",
    "@midwayjs/ws": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.0.0",
    "bunyan": "^1.8.15",
    "dotenv": "^17.4.2",
    "elasticsearch": "^16.7.2",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.29.0",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@midwayjs/bundle-helper": "^1.3.0",
    "@midwayjs/cli": "^2.1.1",
    "@midwayjs/mock": "^3.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/bull": "^3.15.0",
    "@types/elasticsearch": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/node": "^14.0.0",
    "@types/uuid": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^8.0.0",
    "jest": "^30.4.2",
    "mwtsc": "^1.16.0",
    "ts-node": "^10.0.0",
    "typescript": "^4.0.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:xgbbing/node-server.git"
  },
  "author": "Alice Xu <xgb.xu@qq.com>",
  "license": "MIT"
}
