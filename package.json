{
  "name": "node-server",
  "version": "1.0.0",
  "private": true,
  "description": "A Midway + Egg + SQLite + TypeScript project with authentication, scheduled tasks, queue, ES, remote calls, API, templates, and more",
  "scripts": {
    "dev": "cross-env NODE_ENV=local midway-bin dev --ts",
    "build": "midway-bin build -c",
    "start": "NODE_ENV=production node dist",
    "test": "cross-env NODE_ENV=test midway-bin test --ts",
    "cov": "cross-env NODE_ENV=test midway-bin cov --ts",
    "lint": "eslint --ext .ts,.js .",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "typeorm:gen": "npm run typeorm migration:generate -- -d ormconfig.ts",
    "typeorm:run": "npm run typeorm migration:run -- -d ormconfig.ts"
  },
  "dependencies": {
    "@midwayjs/axios": "^3.0.0",
    "@midwayjs/core": "^3.0.0",
    "@midwayjs/decorator": "^3.0.0",
    "@midwayjs/info": "^3.0.0",
    "@midwayjs/jwt": "^3.0.0",
    "@midwayjs/koa": "^3.0.0",
    "@midwayjs/logger": "^3.0.0",
    "@midwayjs/session": "^3.0.0",
    "@midwayjs/typeorm": "^3.0.0",
    "@midwayjs/validate": "^3.0.0",
    "@midwayjs/view-nunjucks": "^3.0.0",
    "@midwayjs/web": "^3.0.0",
    "@midwayjs/ws": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.0.0",
    "bunyan": "^1.8.15",
    "egg": "^2.0.0",
    "egg-scripts": "^2.6.0",
    "egg-view-nunjucks": "^2.2.0",
    "elasticsearch": "^16.7.2",
    "jest": "^30.4.2",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.0",
    "reflect-metadata": "^0.1.13",
    "sqlite3": "^5.0.0",
    "ts-jest": "^29.4.11",
    "typeorm": "^0.3.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@midwayjs/cli": "^1.3.0",
    "@midwayjs/mock": "^3.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/bull": "^3.15.0",
    "@types/elasticsearch": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/lodash": "^4.14.170",
    "@types/node": "^14.0.0",
    "@types/uuid": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^4.0.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:xgbbing/node-server.git"
  },
  "author": "Alice Xu <xgb.xu@qq.com>",
  "license": "MIT"
}
